NODE_ENV=development
PORT=5000

DATABASE_URL="mongodb://localhost:27017/battery_swap_db?replicaSet=rs0"

JWT_ACCESS_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
JWT_REFRESH_SECRET="replace-with-another-long-random-secret-at-least-32-characters"

JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

BCRYPT_SALT_ROUNDS=12

CLIENT_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"
SWAGGER_ENABLED=true
SWAGGER_SERVER_URL="http://localhost:5000"

LOG_LEVEL="debug"

# General API protection. Auth endpoints also have stricter dedicated limits.
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=1000

# VNPay Configuration
VNPAY_TMN_CODE="YOUR_TMN_CODE"
VNPAY_HASH_SECRET="YOUR_HASH_SECRET"
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_RETURN_URL="http://localhost:5000/api/v1/payments/vnpay/return"
