generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum RoleName {
  GUEST
  MEMBER
  STAFF
  TECHNICIAN
  MANAGER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum AuthProvider {
  LOCAL
  GOOGLE
  BOTH
}

enum VehicleStatus {
  ACTIVE
  NEEDS_INSPECTION
  UNSAFE
  SWAP_PENDING
  MAINTENANCE
  TRANSFER_PENDING
  LOCKED
  INACTIVE
}

enum VehicleLockCategory {
  OWNERSHIP_DISPUTE
  REPORTED_STOLEN
  FRAUD_SUSPECTED
  INVALID_VIN
  SAFETY_RISK
  OTHER
}

enum VehicleIncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VehicleIncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum VehicleMaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum IdentifierCorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VehicleOwnershipStatus {
  ACTIVE
  TRANSFER_PENDING
  LOCKED
  INACTIVE
}

enum TransferRequestType {
  USED_VEHICLE_PURCHASE
  LOST_OLD_ACCOUNT
  CHANGED_PHONE_NUMBER
  OTHER
}

enum TransferRequestStatus {
  DRAFT
  PENDING
  UNDER_REVIEW
  NEED_MORE_INFORMATION
  APPROVED
  REJECTED
  CANCELLED
}

enum AccountRecoveryRequestStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum StationStatus {
  DRAFT
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum ServiceBayStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  INACTIVE
}

enum ReplacementSlotStatus {
  AVAILABLE
  FULL
  TEMPORARILY_RESERVED
  BLOCKED
  MAINTENANCE
  CANCELLED
  COMPLETED
}

enum StationMaintenanceType {
  STATION_MAINTENANCE
  BAY_MAINTENANCE
  BATTERY_MAINTENANCE
  INCIDENT
}

enum StationMaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum StationMaintenanceSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BatteryStatus {
  READY
  CHARGING
  MAINTENANCE
  FAULTY
}

enum SlotStatus {
  EMPTY
  CHARGING
  READY
  MAINTENANCE
}

// Kept separate from SlotStatus because SlotStatus describes physical battery
// cabinets, while this enum describes bookable service-bay time windows.
enum BayTimeSlotStatus {
  AVAILABLE
  OFF
  RESERVED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  BLOCKED
  CANCELLED
  EXPIRED
}

enum BookingStatus {
  CREATED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  RESCHEDULE_PROPOSED
  RESCHEDULED
  CHECKED_IN
  COMPLETED
  CANCELLED
  EXPIRED
}

enum TransactionStatus {
  SUCCESS
  FAILED
}

enum InvoiceStatus {
  PAID
  UNPAID
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  MOMO
  VNPAY
  CARD
  WALLET
  CASH
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum MaintenanceSeverity {
  LOW
  WARNING
  CRITICAL
}

enum BatteryOwnershipType {
  OWNED
  SUBSCRIPTION
  LEASED
  UNKNOWN
}

enum BatteryHealthClassification {
  HEALTHY
  LIMITED
  NEEDS_MAINTENANCE
  REPLACEMENT_REQUIRED
  UNSAFE
  UNKNOWN
}

enum BatteryHealthSource {
  AGE_BASED_ESTIMATION
  LIFECYCLE_SIMULATION
  SIMULATED_DIAGNOSTIC
  MANUAL_INSPECTION
  UNKNOWN
}

enum StationAssignmentRole {
  STAFF
  TECHNICIAN
  MANAGER
}

enum BatterySafetyState {
  UNKNOWN
  SAFE
  WARNING
  UNSAFE
}

enum BatteryOperationalStatus {
  AVAILABLE
  RESERVED
  INSTALLED
  REMOVED
  INSPECTION_REQUIRED
  MAINTENANCE
  RETIRED
  QUARANTINED
}

enum ReplacementRequestStatus {
  CREATED
  USER_NOTIFIED
  BOOKING_REQUIRED
  BOOKED
  CANCELLED
  COMPLETED
}

enum SwapStatus {
  NOT_STARTED
  VERIFIED
  OLD_BATTERY_REMOVED
  OLD_BATTERY_INSPECTED
  REPLACEMENT_ASSIGNED
  INSTALLED
  PAYMENT_PENDING
  COMPLETED
  FAILED
  ROLLED_BACK
}

enum NotificationType {
  BATTERY_WARNING
  MANDATORY_REPLACEMENT
  BOOKING_UPDATE
  PAYMENT_UPDATE
  SYSTEM
  VEHICLE_TRANSFER
  ACCOUNT_RECOVERY
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum ReservationStatus {
  ACTIVE
  CONSUMED
  RELEASED
  EXPIRED
}

enum BookingApprovalAction {
  APPROVED
  REJECTED
  RESCHEDULE_PROPOSED
  RESCHEDULE_CONFIRMED
}

enum BatteryInspectionOutcome {
  AVAILABLE
  MAINTENANCE
  QUARANTINED
  RETIRED
}

model Role {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  name      RoleName         @unique
  users     User[]
  grants    RolePermission[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("roles")
}

model Permission {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  code        String           @unique
  description String?
  grants      RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  roleId       String     @db.ObjectId
  permissionId String     @db.ObjectId
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model User {
  id                        String                     @id @default(auto()) @map("_id") @db.ObjectId
  roleId                    String                     @db.ObjectId
  fullName                  String
  phone                     String?
  email                     String                     @unique
  emailVerifiedAt           DateTime?
  emailVerificationRequired Boolean?                   @default(false)
  passwordHash              String
  googleId                  String?                    @unique
  authProvider              AuthProvider               @default(LOCAL)
  rfidCard                  String?
  licensePlate              String?
  avatarUrl                 String?
  status                    UserStatus                 @default(ACTIVE)
  role                      Role                       @relation(fields: [roleId], references: [id])
  wallet                    Wallet?
  vehicles                  Vehicle[]
  bookings                  Booking[]
  swapTransactions          SwapTransaction[]
  subscriptions             Subscription[]
  refreshSessions           RefreshSession[]
  maintenanceRecords        MaintenanceRecord[]        @relation("TechnicianMaintenanceRecords")
  auditLogs                 AuditLog[]                 @relation("AdminAuditLogs")
  createdBayTimeSlots       BayTimeSlot[]              @relation("BayTimeSlotCreatedBy")
  updatedBayTimeSlots       BayTimeSlot[]              @relation("BayTimeSlotUpdatedBy")
  payments                  PaymentTransaction[]
  stationAssignments        StationAssignment[]
  batteryAssignments        VehicleBatteryAssignment[] @relation("BatteryAssignmentActor")
  lifecycleEvents           BatteryLifecycleEvent[]    @relation("LifecycleEventActor")
  notifications             Notification[]
  emailVerificationTokens   EmailVerificationToken[]
  approvedBookings          Booking[]                  @relation("BookingApprover")
  bookingApprovals          BookingApprovalHistory[]   @relation("BookingApprovalManager")
  staffedSwaps              SwapTransaction[]          @relation("SwapStaff")
  batteryInspections        BatteryInspection[]        @relation("BatteryInspector")
  swapStepHistory           SwapStepHistory[]          @relation("SwapStepActor")
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@index([roleId])
  @@index([status])
  @@index([authProvider])
  @@map("users")
}

model EmailVerificationToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  tokenHash String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model RefreshSession {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_sessions")
}

model Vehicle {
  id                      String                               @id @default(auto()) @map("_id") @db.ObjectId
  userId                  String                               @db.ObjectId
  name                    String
  plateNumber             String                               @unique
  vinNumber               String?                              @unique
  qrCode                  String?                              @unique
  brand                   String?
  model                   String?
  manufactureYear         Int?
  purchaseDate            DateTime?
  currentMileageKm        Float?                               @default(0)
  batteryType             String
  batteryOwnershipType    BatteryOwnershipType                 @default(UNKNOWN)
  color                   String?
  vehicleImageUrl         String?
  registrationDocumentUrl String?
  preferredStationId      String?
  currentBatteryId        String?
  note                    String?
  isDeleted               Boolean                              @default(false)
  deletedAt               DateTime?
  deletedBy               String?
  vehicleModelId          String?                              @db.ObjectId
  batteryCount            Int                                  @default(1)
  status                  VehicleStatus                        @default(ACTIVE)
  previousStatus          VehicleStatus?
  lockedAt                DateTime?
  lockedBy                String?                              @db.ObjectId
  lockCategory            VehicleLockCategory?
  lockReason              String?
  lockNotes               String?
  unlockedAt              DateTime?
  unlockedBy              String?                              @db.ObjectId
  inactiveAt              DateTime?
  inactiveBy              String?                              @db.ObjectId
  inactiveReason          String?
  ownershipStatus         VehicleOwnershipStatus               @default(ACTIVE)
  user                    User                                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleModel            VehicleModel?                        @relation(fields: [vehicleModelId], references: [id], onDelete: SetNull)
  batteryAssignments      VehicleBatteryAssignment[]
  batteryHistories        VehicleBatteryHistory[]
  mileageHistories        VehicleMileageHistory[]
  replacementRequests     ReplacementRequest[]
  bookings                Booking[]
  swapTransactions        SwapTransaction[]
  ownershipHistories      VehicleOwnershipHistory[]
  transferRequests        VehicleTransferRequest[]
  vehicleMaintenance      VehicleMaintenanceRecord[]
  incidents               VehicleIncident[]
  identifierCorrections   VehicleIdentifierCorrectionRequest[]
  createdAt               DateTime                             @default(now())
  updatedAt               DateTime                             @updatedAt

  @@index([userId])
  @@index([status])
  @@index([ownershipStatus])
  @@index([vehicleModelId])
  @@map("vehicles")
}

model VehicleMaintenanceRecord {
  id                     String                   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId              String                   @db.ObjectId
  code                   String                   @unique
  type                   String
  description            String
  stationId              String?                  @db.ObjectId
  technicianId           String?                  @db.ObjectId
  expectedStartDate      DateTime
  expectedCompletionDate DateTime?
  completedAt            DateTime?
  result                 String?
  safetyResult           BatterySafetyState?
  status                 VehicleMaintenanceStatus @default(SCHEDULED)
  notes                  String?
  vehicle                Vehicle                  @relation(fields: [vehicleId], references: [id])
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  @@index([vehicleId, createdAt])
  @@index([status])
  @@map("vehicle_maintenance_records")
}

model VehicleIncident {
  id          String                  @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId   String                  @db.ObjectId
  code        String                  @unique
  type        String
  severity    VehicleIncidentSeverity
  description String
  reporterId  String?                 @db.ObjectId
  status      VehicleIncidentStatus   @default(OPEN)
  resolution  String?
  resolvedAt  DateTime?
  vehicle     Vehicle                 @relation(fields: [vehicleId], references: [id])
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([vehicleId, createdAt])
  @@index([severity, status])
  @@map("vehicle_incidents")
}

model VehicleIdentifierCorrectionRequest {
  id          String                     @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId   String                     @db.ObjectId
  field       String
  oldValue    String
  newValue    String
  reason      String
  requestedBy String                     @db.ObjectId
  reviewedBy  String?                    @db.ObjectId
  reviewedAt  DateTime?
  status      IdentifierCorrectionStatus @default(PENDING)
  vehicle     Vehicle                    @relation(fields: [vehicleId], references: [id])
  createdAt   DateTime                   @default(now())

  @@index([vehicleId, createdAt])
  @@index([status])
  @@map("vehicle_identifier_correction_requests")
}

model VehicleModel {
  id              String                 @id @default(auto()) @map("_id") @db.ObjectId
  manufacturer    String
  name            String
  modelYear       Int?
  connectorType   String
  nominalVoltage  Float
  batteryClass    String
  vehicles        Vehicle[]
  compatibilities BatteryCompatibility[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([manufacturer, name, modelYear])
  @@map("vehicle_models")
}

model Wallet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  balance   Int      @default(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wallets")
}

model Station {
  id                       String              @id @default(auto()) @map("_id") @db.ObjectId
  code                     String              @unique
  name                     String
  description              String?
  phone                    String?
  email                    String?
  country                  String?
  province                 String?
  district                 String?
  ward                     String?
  address                  String
  latitude                 Float
  longitude                Float
  openingTime              String?
  closingTime              String?
  workingDays              String[]
  holidaySupport           Boolean             @default(false)
  maintenanceDay           String?
  serviceBaysCount         Int                 @default(1)
  maxVehiclesPerSlot       Int                 @default(1)
  defaultSlotDuration      Int                 @default(30)
  baySlotBufferMinutes     Int?                @default(0)
  allowParallelReplacement Boolean             @default(false)
  supportedVehicleModelIds String[]            @db.ObjectId
  supportedBatteryTypeIds  String[]            @db.ObjectId
  status                   StationStatus       @default(ACTIVE)
  slots                    BatterySlot[]
  bookings                 Booking[]
  swapTransactions         SwapTransaction[]
  assignments              StationAssignment[]
  batteries                Battery[]
  safetyRules              BatterySafetyRule[]
  serviceBays              ServiceBay[]
  bayTimeSlots             BayTimeSlot[]
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  @@index([status])
  @@map("stations")
}

model StationAssignment {
  id             String                @id @default(auto()) @map("_id") @db.ObjectId
  userId         String                @db.ObjectId
  stationId      String                @db.ObjectId
  assignmentRole StationAssignmentRole
  active         Boolean               @default(true)
  effectiveFrom  DateTime              @default(now())
  effectiveTo    DateTime?
  shift          String?
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  station        Station               @relation(fields: [stationId], references: [id], onDelete: Cascade)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([userId, stationId, assignmentRole])
  @@index([stationId, active])
  @@map("station_assignments")
}

model ServiceBay {
  id                     String           @id @default(auto()) @map("_id") @db.ObjectId
  stationId              String           @db.ObjectId
  bayCode                String
  bayName                String
  status                 ServiceBayStatus @default(AVAILABLE)
  defaultDurationMinutes Int              @default(30)
  description            String?
  station                Station          @relation(fields: [stationId], references: [id], onDelete: Cascade)
  bookings               Booking[]
  reservations           BayReservation[]
  timeSlots              BayTimeSlot[]
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@unique([stationId, bayCode])
  @@index([stationId, status])
  @@map("service_bays")
}

model ReplacementSlot {
  id            String                @id @default(auto()) @map("_id") @db.ObjectId
  stationId     String                @db.ObjectId
  bayId         String                @db.ObjectId
  date          DateTime
  startTime     String
  endTime       String
  capacity      Int
  bookedCount   Int                   @default(0)
  reservedCount Int                   @default(0)
  status        ReplacementSlotStatus @default(AVAILABLE)
  recurrence    Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([stationId, date])
  @@index([bayId, date, startTime])
  @@map("replacement_slots")
}

model StationMaintenanceEvent {
  id                 String                     @id @default(auto()) @map("_id") @db.ObjectId
  stationId          String                     @db.ObjectId
  type               StationMaintenanceType
  relatedEntityId    String?
  relatedEntityLabel String?
  title              String
  description        String
  severity           StationMaintenanceSeverity
  status             StationMaintenanceStatus   @default(OPEN)
  assignedStaffId    String?                    @db.ObjectId
  startTime          DateTime                   @default(now())
  expectedCompletion DateTime?
  actualCompletion   DateTime?
  resolution         String?
  createdById        String                     @db.ObjectId
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([stationId, status, createdAt])
  @@index([assignedStaffId])
  @@map("station_maintenance_events")
}

model BatterySlot {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  stationId    String            @db.ObjectId
  slotNumber   Int
  status       SlotStatus        @default(EMPTY)
  station      Station           @relation(fields: [stationId], references: [id], onDelete: Cascade)
  batteries    Battery[]         @relation("SlotBattery")
  bookings     Booking[]
  reservations SlotReservation[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([stationId, slotNumber])
  @@index([stationId])
  @@index([status])
  @@map("battery_slots")
}

model Battery {
  id                          String                      @id @default(auto()) @map("_id") @db.ObjectId
  batteryCode                 String                      @unique
  qrCodeValue                 String?
  serialNumber                String?                     @unique
  soc                         Int
  soh                         Float
  temperature                 Float                       @default(25)
  voltage                     Float                       @default(400)
  type                        String?
  batteryTypeId               String?                     @db.ObjectId
  stationId                   String?                     @db.ObjectId
  cycleCount                  Int                         @default(0)
  manufacturer                String?
  manufacturedDate            DateTime?
  manufacturedAt              DateTime?
  receivedAt                  DateTime?
  activatedDate               DateTime?
  ratedCapacityAh             Float?
  ratedVoltage                Float?
  simulatedMeasuredCapacityAh Float?
  accumulatedMileageKm        Float?                      @default(0)
  accumulatedDistance         Float?                      @default(0)
  estimatedSoH                Float?
  healthClassification        BatteryHealthClassification @default(UNKNOWN)
  healthSource                BatteryHealthSource         @default(UNKNOWN)
  currentVehicleId            String?
  reservedForSwapId           String?
  lastEstimatedAt             DateTime?
  safetyState                 BatterySafetyState          @default(SAFE)
  operationalStatus           BatteryOperationalStatus    @default(AVAILABLE)
  lastHealthCheckAt           DateTime?
  status                      BatteryStatus               @default(READY)
  condition                   String?                     @default("NEW")
  storageLocation             String?
  note                        String?
  createdById                 String?                     @db.ObjectId
  slotId                      String?                     @db.ObjectId
  slot                        BatterySlot?                @relation("SlotBattery", fields: [slotId], references: [id], onDelete: SetNull)
  batteryType                 BatteryType?                @relation(fields: [batteryTypeId], references: [id], onDelete: SetNull)
  station                     Station?                    @relation(fields: [stationId], references: [id], onDelete: SetNull)
  bookings                    Booking[]
  batteryInTransactions       SwapTransaction[]           @relation("BatteryInTransactions")
  batteryOutTransactions      SwapTransaction[]           @relation("BatteryOutTransactions")
  maintenanceRecords          MaintenanceRecord[]
  healthLogs                  BatteryHealthLog[]
  vehicleAssignments          VehicleBatteryAssignment[]
  vehicleHistories            VehicleBatteryHistory[]
  replacementRequests         ReplacementRequest[]
  lifecycleEvents             BatteryLifecycleEvent[]
  reservations                BatteryReservation[]
  inspections                 BatteryInspection[]
  movements                   BatteryMovement[]
  lastUpdated                 DateTime                    @default(now())
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt

  @@index([status])
  @@index([batteryTypeId])
  @@index([stationId, operationalStatus, safetyState])
  @@index([condition])
  @@index([stationId, status])
  @@map("batteries")
}

model BatteryMovement {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  batteryId    String   @db.ObjectId
  movementType String
  fromLocation String?
  toStationId  String?  @db.ObjectId
  toLocation   String?
  performedBy  String   @db.ObjectId
  note         String?
  createdAt    DateTime @default(now())
  battery      Battery  @relation(fields: [batteryId], references: [id], onDelete: Cascade)

  @@index([batteryId])
  @@index([toStationId])
  @@map("battery_movements")
}

model BatteryType {
  id              String                 @id @default(auto()) @map("_id") @db.ObjectId
  code            String                 @unique
  manufacturer    String?
  chemistry       String?
  connectorType   String?
  nominalVoltage  Float
  capacityKWh     Float
  batteryClass    String?
  batteries       Battery[]
  compatibilities BatteryCompatibility[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@map("battery_types")
}

model BatteryCompatibility {
  id                 String       @id @default(auto()) @map("_id") @db.ObjectId
  vehicleModelId     String       @db.ObjectId
  batteryTypeId      String       @db.ObjectId
  connectorType      String
  nominalVoltage     Float
  minimumCapacityKWh Float
  maximumCapacityKWh Float
  batteryClass       String
  active             Boolean      @default(true)
  vehicleModel       VehicleModel @relation(fields: [vehicleModelId], references: [id], onDelete: Cascade)
  batteryType        BatteryType  @relation(fields: [batteryTypeId], references: [id], onDelete: Cascade)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([vehicleModelId, batteryTypeId])
  @@index([batteryTypeId, active])
  @@map("battery_compatibilities")
}

model BatterySafetyRule {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  stationId          String?   @db.ObjectId
  version            Int
  minimumSohSafe     Int
  minimumSohWarning  Int
  minimumSoc         Int
  maximumTemperature Float
  minimumVoltage     Float
  maximumVoltage     Float
  effectiveFrom      DateTime
  effectiveTo        DateTime?
  active             Boolean   @default(true)
  station            Station?  @relation(fields: [stationId], references: [id], onDelete: SetNull)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([stationId, version])
  @@index([active, effectiveFrom])
  @@map("battery_safety_rules")
}

model VehicleBatteryAssignment {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId    String    @db.ObjectId
  batteryId    String    @db.ObjectId
  assignedById String?   @db.ObjectId
  active       Boolean   @default(true)
  assignedAt   DateTime  @default(now())
  removedAt    DateTime?
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  battery      Battery   @relation(fields: [batteryId], references: [id], onDelete: Cascade)
  assignedBy   User?     @relation("BatteryAssignmentActor", fields: [assignedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([vehicleId, active])
  @@index([batteryId, active])
  @@map("vehicle_battery_assignments")
}

model ReplacementRequest {
